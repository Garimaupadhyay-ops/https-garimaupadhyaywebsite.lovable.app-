export function getPathwaysForOrgan(organ: Organ) {
  return PATHWAY_LOCATIONS.filter(
    (pathway) =>
      pathway.primaryOrgans.includes(organ) ||
      pathway.secondaryOrgans.includes(organ) ||
      pathway.primaryOrgans.includes('all'),
  );
}

export function getPathwaysForOrganelle(organelle: string) {
  const needle = organelle.toLowerCase();
  return PATHWAY_LOCATIONS.filter((pathway) =>
    pathway.organelles.some((item) => item.toLowerCase().includes(needle)),
  );
}
